{
  "name": "vscode-mcp-bridge",
  "displayName": "VS Code MCP Bridge",
  "description": "Bridge between MCP Server and VS Code — enables remote control via Claude",
  "version": "1.0.0",
  "publisher": "promobrindes",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["*"],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "VS Code MCP Bridge",
      "properties": {
        "vscodeMcp.bridgeSecret": {
          "type": "string",
          "default": "",
          "description": "Shared secret for authenticating with the MCP server bridge"
        },
        "vscodeMcp.bridgeHost": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host of the MCP bridge WebSocket server"
        },
        "vscodeMcp.bridgePort": {
          "type": "number",
          "default": 7100,
          "description": "Port of the MCP bridge WebSocket server"
        },
        "vscodeMcp.allowedCommands": {
          "type": "array",
          "default": [],
          "description": "Additional VS Code commands allowed via MCP (beyond the default safe list)"
        },
        "vscodeMcp.todosFilePath": {
          "type": "string",
          "default": ".vscode/todos.json",
          "description": "Path for the todos file relative to workspace root"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run build -- --watch",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.20.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ws": "^8.16.0"
  }
}
