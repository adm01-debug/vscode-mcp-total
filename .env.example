# ============================================================
# VS Code MCP Total — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o .env com valores reais!
#
# Para gerar valores seguros:
#   node scripts/generate-secrets.js
# ============================================================

# ── Servidor MCP ────────────────────────────────────────────
# Porta onde o servidor MCP vai escutar
MCP_PORT=7337

# Token de autenticação — vai na URL do conector Claude
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# URL do conector: https://SEU_DOMINIO/mcp/TOKEN_AQUI
MCP_TOKEN=GERE_UM_TOKEN_LONGO_ALEATORIO_AQUI

# ── Ponte WebSocket (Bridge) ────────────────────────────────
# Porta da ponte entre o servidor MCP e a extensão VS Code
BRIDGE_PORT=7100

# Segredo compartilhado extensão ↔ servidor (deve ser DIFERENTE do MCP_TOKEN)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Configure o MESMO valor em: VS Code Settings > vscodeMcp.bridgeSecret
BRIDGE_SECRET=GERE_UM_SEGREDO_DIFERENTE_DO_TOKEN_AQUI

# ── code-server (VS Code no browser) ───────────────────────
# Senha de acesso ao code-server (http://localhost:8443)
# Gere com: node -e "console.log(require('crypto').randomBytes(12).toString('base64url'))"
CODE_SERVER_PASSWORD=SENHA_DE_ACESSO_AO_VSCODE_WEB
