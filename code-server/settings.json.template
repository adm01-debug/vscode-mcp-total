{
  "vscodeMcp.enable": true,
  "vscodeMcp.bridgeHost": "mcp-server",
  "vscodeMcp.bridgePort": 7100,
  "vscodeMcp.bridgeSecret": "__BRIDGE_SECRET__",
  "vscodeMcp.requireApproval": false,
  "vscodeMcp.logLevel": "info",

  "editor.fontSize": 14,
  "editor.tabSize": 2,
  "editor.formatOnSave": false,
  "terminal.integrated.fontSize": 13,
  "files.autoSave": "off",
  "git.autofetch": true,
  "workbench.colorTheme": "Default Dark Modern"
}
